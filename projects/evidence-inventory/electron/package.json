{
  "name": "evidence-inventory",
  "version": "1.0.0",
  "description": "Inventario de evidencia industrial",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.tomiandrade.evidence-inventory",
    "productName": "Evidence Inventory",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "../backend/src/**/*",
      "../backend/package.json",
      "../backend/node_modules/**/*",
      "../frontend/dist/**/*"
    ],
    "extraResources": [
      { "from": "../backend", "to": "backend" },
      { "from": "../frontend/dist", "to": "frontend/dist" }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "signAndEditExecutable": false
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0"
  }
}
