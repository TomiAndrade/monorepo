# Copiá este archivo a .env y completá tu API key.
# El archivo .env NO se sube a git (está en .gitignore).

# --- Modo directo (api-sports.io) ---
# Registrate en https://www.api-football.com/ y pegá tu key acá.
API_FOOTBALL_KEY=pega_tu_api_key_aca
API_FOOTBALL_HOST=v3.football.api-sports.io

# Puerto donde corre el backend
PORT=3001

# --- Si te registraste por RapidAPI en vez de directo ---
# Comentá las dos líneas de arriba y usá estas:
# API_FOOTBALL_KEY=tu_rapidapi_key
# API_FOOTBALL_HOST=api-football-v1.p.rapidapi.com
# (y en src/apiFootball.js cambiá el header x-apisports-key por x-rapidapi-key)
