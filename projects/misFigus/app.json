{
  "expo": {
    "name": "misFigus",
    "slug": "misFigus",
    "scheme": "misfigus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logofigus.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.tomiandrade.misfigus",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/logofigus.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d387ea54-7699-455c-8208-aaee170dee00"
      }
    }
  }
}
