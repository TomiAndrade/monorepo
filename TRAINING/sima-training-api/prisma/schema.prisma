// Prisma schema — SIMA Training API

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Tipo de organización dentro de la jerarquía cliente → subcontratista.
enum TipoOrganizacion {
  CLIENTE
  SUBCONTRATISTA
  INTERNA
}

// Rol de la vinculación persona↔organización. Vivió transitoriamente en
// Usuario hasta que se implementó Vinculacion (ver docs/modelo-vinculacion-propuesto.md).
enum RolUsuario {
  ADMINISTRADOR
  COORDINADOR
  AUDITOR
  ALUMNO
}

// Organizacion: clientes y subcontratistas. La jerarquía se modela con una
// FK self-referencial (un subcontratista cuelga de un cliente).
model Organizacion {
  id                  Int              @id @default(autoincrement())
  nombre              String
  tipo                TipoOrganizacion @default(CLIENTE)
  organizacionPadreId Int?             @map("organizacion_padre_id")
  activa              Boolean          @default(true)

  // Relación self-referencial
  organizacionPadre Organizacion?  @relation("OrganizacionJerarquia", fields: [organizacionPadreId], references: [id])
  subcontratistas   Organizacion[] @relation("OrganizacionJerarquia")

  vinculaciones Vinculacion[]

  // Trazabilidad
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("organizaciones")
}

// Usuario: identidad pura de cualquier persona (cuenta de sistema y/o persona
// evaluada). Rol, organización y clasificación se movieron a Vinculacion
// (ver docs/modelo-vinculacion-propuesto.md); acá solo queda lo que identifica
// a la persona en sí.
model Usuario {
  id       Int     @id @default(autoincrement())
  nombre   String
  apellido String
  dni      String  @unique
  email    String?

  vinculacion Vinculacion?

  asignaciones Asignacion[]

  // Datos flexibles de nómina (jsonb). Dato de tránsito: los campos que se
  // estabilicen cuando llegue el Excel real se promueven a columnas (§3.4-a).
  datos Json @default("{}")

  // Trazabilidad
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  // Soft-delete (Sprint 1 implementa la baja que el prototipo no tiene).
  deletedAt DateTime? @map("deleted_at")

  @@map("usuarios")
}

// Tipo de pregunta. Mapeo con los tipos que ya usa el frontend mockeado
// (sima-check/data/training-modules.js):
//   truefalse     -> VERDADERO_FALSO
//   multiple      -> OPCION_MULTIPLE
//   image-options -> OPCIONES_IMAGEN
// TEXTO_LIBRE no tiene equivalente en el mock; se agrega a futuro.
enum TipoPregunta {
  VERDADERO_FALSO
  OPCION_MULTIPLE
  OPCIONES_IMAGEN
  TEXTO_LIBRE
}

enum CategoriaEtiqueta {
  TEMA
  AREA
  NORMA
  ROL
}

enum EstadoVersionModulo {
  BORRADOR
  ACTIVO
  ARCHIVADO
}

// Origen de una Asignacion: la derivó recalcular() a partir de una regla, o la
// cargó un admin a mano. recalcular() sólo crea/revoca las AUTOMATICA — nunca
// toca las MANUAL.
enum OrigenAsignacion {
  AUTOMATICA
  MANUAL
}

// Pregunta: única, puede pertenecer a varios módulos (vía ModuloVersionPregunta).
// Nunca se duplica el texto de una pregunta.
model Pregunta {
  id                String       @id @default(uuid())
  texto             String
  tipo              TipoPregunta
  // Opciones (OPCION_MULTIPLE / OPCIONES_IMAGEN): array de strings (texto o rutas de imagen).
  opciones          Json?
  // Equivalente a `correctAnswer` del mock. Nullable: TEXTO_LIBRE puede no tener una fija.
  respuestaCorrecta String?      @map("respuesta_correcta")
  // Ruta relativa a public/, equivalente al campo `image` del mock.
  imagen            String?
  puntajeMax        Int?         @map("puntaje_max")
  activa            Boolean      @default(true)

  etiquetas PreguntaEtiqueta[]
  versiones ModuloVersionPregunta[]

  // Trazabilidad
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")

  @@map("preguntas")
}

model Etiqueta {
  id        String            @id @default(uuid())
  nombre    String            @unique @db.VarChar(80)
  categoria CategoriaEtiqueta
  color     String?           @db.VarChar(7)

  preguntas PreguntaEtiqueta[]

  @@map("etiquetas")
}

// Pivot Pregunta <-> Etiqueta (N a N).
model PreguntaEtiqueta {
  preguntaId String @map("pregunta_id")
  etiquetaId String @map("etiqueta_id")

  pregunta Pregunta @relation(fields: [preguntaId], references: [id])
  etiqueta Etiqueta @relation(fields: [etiquetaId], references: [id])

  @@id([preguntaId, etiquetaId])
  @@map("pregunta_etiquetas")
}

// Módulo: contenedor estable de versiones. El contenido real (preguntas)
// vive en ModuloVersion, nunca acá directamente.
model Modulo {
  id            String  @id @default(uuid())
  nombre        String  @db.VarChar(200)
  descripcion   String?
  // Baja lógica del módulo entero (independiente del ciclo BORRADOR/ACTIVO/ARCHIVADO
  // de sus versiones): el admin lo retira/reactiva a mano.
  activo        Boolean @default(true)
  // Cada cuántos meses un alumno debe rendir de nuevo este módulo para seguir
  // certificado. Nullable: módulos sin cadencia de recertificación definida.
  vigenciaMeses Int?    @map("vigencia_meses")

  versiones        ModuloVersion[]
  reglasAsignacion ReglaAsignacion[]
  asignaciones     Asignacion[]

  // Trazabilidad
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")

  @@map("modulos")
}

// Versión de un módulo. Editar un módulo activo crea una versión nueva;
// las versiones anteriores quedan ARCHIVADO e inmutables (no se pierden).
model ModuloVersion {
  id            String              @id @default(uuid())
  moduloId      String              @map("modulo_id")
  // Contador monotónico interno (orden de creación). El número público es anio.mayor.menor.
  numeroVersion Int                 @map("numero_version")
  estado        EstadoVersionModulo @default(BORRADOR)

  // Número público AÑO.MAYOR.MENOR (ej. 2026.01.00). Se asigna al Activar (publicar);
  // un BORRADOR sin publicar los tiene en null y se muestra como "Borrador".
  // MAYOR = secuencia por módulo por año; MENOR = revisión dentro de esa línea.
  anio         Int?      @map("anio")
  mayor        Int?
  menor        Int?
  // Timestamp de publicación (para ordenar el historial).
  activadaEn   DateTime? @map("activada_en")
  // Elección guardada en el borrador: true = versión nueva (sube MAYOR), false = actualización
  // (sube MENOR). null para v1 / primera publicación (no hay de qué derivar).
  esNuevaLinea Boolean?  @map("es_nueva_linea")

  modulo       Modulo                  @relation(fields: [moduloId], references: [id])
  preguntas    ModuloVersionPregunta[]
  asignaciones Asignacion[]

  // Trazabilidad
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")

  @@unique([moduloId, numeroVersion])
  @@unique([moduloId, anio, mayor, menor])
  @@map("modulo_versiones")
}

// Puesto: catálogo de puestos/cargos de nómina. Baja lógica vía `activo`.
model Puesto {
  id     String  @id @default(uuid())
  nombre String  @unique
  activo Boolean @default(true)

  vinculaciones    VinculacionPuestoCentro[]
  reglasAsignacion ReglaAsignacion[]

  // Trazabilidad
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")

  @@map("puestos")
}

// CentroCosto: catálogo de centros de costo de nómina. Baja lógica vía `activo`.
model CentroCosto {
  id     String  @id @default(uuid())
  nombre String  @unique
  activo Boolean @default(true)

  vinculaciones    VinculacionPuestoCentro[]
  reglasAsignacion ReglaAsignacion[]

  // Trazabilidad
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")

  @@map("centros_costo")
}

// Vinculacion: vínculo persona ↔ organización (una por usuario — el @unique
// en usuarioId es la regla "una sola organización" verificada por Postgres).
// Guarda lo que es único por persona: organización y rol. Puesto y centro de
// costo se repiten y van siempre juntos: viven apareados en VinculacionPuestoCentro.
// Reemplaza a Usuario.rol/organizacionId y al concepto de "clasificación"
// (que se elimina: la pertenencia SIMA/CLIENTE/SUBCONTRATISTA se deriva de
// Organizacion.tipo + organizacionPadreId, no se persiste acá).
// Ver docs/modelo-vinculacion-propuesto.md.
model Vinculacion {
  id Int @id @default(autoincrement())

  usuarioId Int     @unique @map("usuario_id")
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  organizacionId Int          @map("organizacion_id")
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id])

  rol RolUsuario

  puestosCentros VinculacionPuestoCentro[]

  activa Boolean @default(true)

  // Trazabilidad
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")

  @@map("vinculaciones")
}

// Un par (puesto, centro de costo) que la persona ejerce dentro de su vinculación.
// Los tres campos de la PK son NOT NULL: un par siempre viene completo — nunca un
// puesto sin centro ni al revés. Reemplaza a VinculacionPuesto + VinculacionCentroCosto,
// que modelaban puesto y centro como ejes independientes: la capacitación obligatoria
// depende del par ("Soldador en YPF" ≠ "Soldador en PAE"), no de dos listas sueltas.
// Por eso el mismo puesto en varios centros SÍ es una fila por centro.
// Ver docs/modelo-vinculacion-propuesto.md §1.1.
model VinculacionPuestoCentro {
  vinculacionId Int    @map("vinculacion_id")
  puestoId      String @map("puesto_id")
  centroCostoId String @map("centro_costo_id")

  vinculacion Vinculacion @relation(fields: [vinculacionId], references: [id])
  puesto      Puesto      @relation(fields: [puestoId], references: [id])
  centroCosto CentroCosto @relation(fields: [centroCostoId], references: [id])

  // Cuál par se muestra como "el" puesto/centro del usuario en listados/tablas.
  // Exactamente UNO en true por vinculación, garantizado por un índice único PARCIAL
  // (UNIQUE (vinculacion_id) WHERE principal) que vive solo en la migración: Prisma
  // no puede expresar un @@unique con WHERE.
  principal Boolean @default(false)
  activo    Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")

  @@id([vinculacionId, puestoId, centroCostoId])
  // Índices invertidos: la regla de asignación filtra por el par exacto entrando por
  // cualquiera de los dos ejes. El `map` es explícito porque el nombre autogenerado
  // pasa el límite de 63 caracteres de Postgres y Prisma lo truncaría.
  @@index([puestoId, centroCostoId, vinculacionId], map: "vinculacion_puesto_centro_puesto_centro_idx")
  @@index([centroCostoId, puestoId, vinculacionId], map: "vinculacion_puesto_centro_centro_puesto_idx")
  @@map("vinculacion_puesto_centro")
}

// Pivot ModuloVersion <-> Pregunta (N a N), con orden y obligatoriedad.
model ModuloVersionPregunta {
  moduloVersionId String  @map("modulo_version_id")
  preguntaId      String  @map("pregunta_id")
  orden           Int
  obligatoria     Boolean @default(true)
  // Baja lógica por módulo: una pregunta no se edita, se desactiva. Solo afecta
  // a este módulo (el banco Pregunta.activa sigue siendo el flag global).
  activa          Boolean @default(true)

  moduloVersion ModuloVersion @relation(fields: [moduloVersionId], references: [id])
  pregunta      Pregunta      @relation(fields: [preguntaId], references: [id])

  @@id([moduloVersionId, preguntaId])
  @@map("modulo_version_preguntas")
}

// ReglaAsignacion: el par (puesto, centro de costo) obliga a rendir un módulo.
// Apunta a Modulo (el contenedor estable), NO a una ModuloVersion: la obligación
// es "este módulo", la versión concreta que se rinda se resuelve al momento de
// rendir. Es el motor de las Asignacion AUTOMATICA (ver AsignacionesService.recalcular):
// los módulos obligatorios se definen por el PAR EXACTO — "Soldador en YPF" puede
// pedir módulos distintos que "Soldador en PAE".
model ReglaAsignacion {
  id            String  @id @default(uuid())
  puestoId      String  @map("puesto_id")
  centroCostoId String  @map("centro_costo_id")
  moduloId      String  @map("modulo_id")
  // Baja lógica: una regla no se borra, se desactiva (deja de generar obligaciones).
  activo        Boolean @default(true)

  puesto      Puesto      @relation(fields: [puestoId], references: [id])
  centroCosto CentroCosto @relation(fields: [centroCostoId], references: [id])
  modulo      Modulo      @relation(fields: [moduloId], references: [id])

  // Trazabilidad
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  // No tiene sentido la misma regla dos veces para el mismo triple. Volver a
  // agregar una regla dada de baja se resuelve reactivando la fila (activo=true).
  @@unique([puestoId, centroCostoId, moduloId])
  @@map("reglas_asignacion")
}

// Asignacion: obligación concreta de una persona de rendir un módulo. Apunta a
// Modulo (el contenedor estable), NO a la versión. Nunca se borra — se revoca
// (revocadaAt): una asignación revocada no cuenta como obligación vigente.
model Asignacion {
  id              String  @id @default(uuid())
  usuarioId       Int     @map("usuario_id")
  moduloId        String  @map("modulo_id")
  // Se completa RECIÉN al rendir: deja registro de qué versión concreta se evaluó.
  // Hoy nadie lo completa (la app tablet sigue mockeada).
  moduloVersionId String? @map("modulo_version_id")

  origen     OrigenAsignacion @default(AUTOMATICA)
  // Baja de la obligación. Null = vigente. Nunca se borra la fila (trazabilidad).
  revocadaAt DateTime?        @map("revocada_at")

  usuario       Usuario        @relation(fields: [usuarioId], references: [id])
  modulo        Modulo         @relation(fields: [moduloId], references: [id])
  moduloVersion ModuloVersion? @relation(fields: [moduloVersionId], references: [id])

  // Trazabilidad
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  // A lo sumo UNA asignación vigente por (usuario, módulo). Se garantiza con un
  // índice único PARCIAL (WHERE revocada_at IS NULL) que vive sólo en la migración
  // — Prisma no expresa WHERE en @@unique (mismo caso que el índice `principal` de
  // vinculacion_puesto_centro). Blinda la idempotencia de recalcular() y deja
  // coexistir una asignación revocada vieja + una vigente nueva (recontratación).
  @@index([usuarioId])
  @@map("asignaciones")
}
