# Puerto del servidor HTTP
PORT=3000

# Conexión a PostgreSQL (local vía docker-compose en el Paso 2)
DATABASE_URL="postgresql://sima:sima@localhost:5432/sima_training?schema=public"

# Secreto para firmar JWT (auth básica, Paso 6)
JWT_SECRET="cambiar-en-produccion"
JWT_EXPIRES_IN="8h"

# Orígenes permitidos por CORS (frontends)
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"
